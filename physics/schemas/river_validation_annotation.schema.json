{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raftsim.local/schemas/river_validation_annotation.schema.json",
  "title": "RaftSim River Validation Annotation Package",
  "type": "object",
  "required": [
    "schema_version",
    "type",
    "package_id",
    "export_targets",
    "features"
  ],
  "properties": {
    "schema_version": {
      "const": "raftsim.river_validation_annotation.v0"
    },
    "type": {
      "const": "FeatureCollection"
    },
    "package_id": {
      "type": "string"
    },
    "export_targets": {
      "type": "array",
      "minItems": 3
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "geometry",
          "properties"
        ]
      }
    }
  }
}
