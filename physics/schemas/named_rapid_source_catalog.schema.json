{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raftsim.local/schemas/named_rapid_source_catalog.schema.json",
  "title": "RaftSim Named Rapid Source Catalog",
  "type": "object",
  "required": ["schema", "status", "rights_policy", "sources", "rivers"],
  "properties": {
    "schema": {"const": "raftsim.real_world.named_rapid_source_catalog.v1"},
    "status": {"const": "review_baseline_not_guide_approved"},
    "rights_policy": {"type": "string", "minLength": 20},
    "sources": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["source_id", "river_id", "title", "url", "source_kind", "rights_status"]
      }
    },
    "rivers": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["river_id", "display_name", "run_length_m", "stationing_authority", "source_ids", "rapids"],
        "properties": {
          "run_length_m": {"type": "number", "exclusiveMinimum": 0},
          "rapids": {"type": "array", "minItems": 1}
        }
      }
    }
  }
}
