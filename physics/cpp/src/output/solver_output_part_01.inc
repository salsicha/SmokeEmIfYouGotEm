void write_solver_output(
    const Scenario& scenario,
    const std::vector<Frame>& frames,
    const ValidationSummary& validation,
    const SolverConfig& config,
    const std::string& output_dir
) {
    fs::path root(output_dir);
    fs::create_directories(root / "frames");
    fs::create_directories(root / "probes");
    fs::create_directories(root / "cross_sections");
    fs::create_directories(root / "diagnostics");

    std::vector<std::string> frame_files;
    for (std::size_t i = 0; i < frames.size(); ++i) {
        std::ostringstream name;
        name << "frames/frame_" << std::setw(4) << std::setfill('0') << i << ".csv";
        write_frame_csv(scenario, frames[i], root / name.str());
        frame_files.push_back(name.str());
    }

    std::vector<std::string> probe_files;
    std::vector<std::string> cross_section_files;
    for (const Probe& probe : scenario.probes) {
        if (probe.kind == "cross_section") {
            std::string relative = "cross_sections/" + probe.id + ".csv";
            write_cross_section_csv(scenario, frames, probe, root / relative);
            cross_section_files.push_back(relative);
        } else {
            std::string relative = "probes/" + probe.id + ".csv";
            write_probe_csv(scenario, frames, probe, root / relative);
            probe_files.push_back(relative);
        }
    }

    std::vector<std::string> diagnostic_files;
    const FixtureGeoclawProfile& constriction_profile =
        constriction_finite_volume_geoclaw_profile();
    const FixtureGeoclawProfile& constriction_reduced_profile =
        constriction_reduced_geoclaw_profile();
    const FixtureGeoclawProfile& drop_ledge_reduced_profile =
        drop_ledge_reduced_geoclaw_profile();
    const FixtureGeoclawProfile& boulder_garden_finite_volume_profile =
        boulder_garden_finite_volume_geoclaw_profile();
    const FixtureGeoclawProfile& boulder_garden_reduced_profile =
        boulder_garden_reduced_geoclaw_profile();
    const FixtureGeoclawProfile& cascading_wave_train_reduced_profile =
        cascading_wave_train_reduced_geoclaw_profile();
    const FixtureGeoclawProfile& cascading_wave_train_finite_volume_profile =
        cascading_wave_train_finite_volume_geoclaw_profile();
    bool constriction_profile_enabled = constriction_finite_volume_geoclaw_profile_enabled(scenario, config);
    bool constriction_reduced_profile_enabled = constriction_reduced_geoclaw_profile_enabled(scenario, config);
    bool drop_ledge_reduced_profile_enabled = drop_ledge_reduced_geoclaw_profile_enabled(scenario, config);
    bool boulder_garden_finite_volume_profile_enabled =
        boulder_garden_finite_volume_geoclaw_profile_enabled(scenario, config);
    bool boulder_garden_reduced_profile_enabled = boulder_garden_reduced_geoclaw_profile_enabled(scenario, config);
    bool cascading_wave_train_reduced_profile_enabled =
        cascading_wave_train_reduced_geoclaw_profile_enabled(scenario, config);
    bool cascading_wave_train_finite_volume_profile_enabled =
        cascading_wave_train_finite_volume_geoclaw_profile_enabled(scenario, config);
    const ScenarioFixtureGeoclawProfile* scenario_fixture_profile =
        scenario_fixture_geoclaw_profile_for(scenario, config);
    if (!config.disable_fixture_calibrations && config.solver_mode == "finite_volume" &&
        scenario.fixture_kind == "constriction" &&
        !constriction_profile_enabled && !frames.empty()) {
        std::string relative = "diagnostics/constriction_y_face_flux_source_audit.csv";
        write_constriction_y_face_flux_source_audit_csv(scenario, frames.back(), config, root / relative);
        diagnostic_files.push_back(relative);
    }

    {
        std::ofstream out(root / "validation.json");
        out << std::setprecision(17)
            << "{\n"
            << "  \"passed\": " << (validation.passed ? "true" : "false") << ",\n"
            << "  \"mass_initial\": " << validation.mass_initial << ",\n"
            << "  \"mass_final\": " << validation.mass_final << ",\n"
            << "  \"mass_relative_drift\": " << validation.mass_relative_drift << ",\n"
            << "  \"max_velocity\": " << validation.max_velocity << ",\n"
            << "  \"min_depth\": " << validation.min_depth << "\n"
            << "}\n";
    }

    const CascadingGeoclawProfileFlow* cascading_profile_flow = cascading_geoclaw_profile_flow_for(scenario);
    bool cascading_profile_enabled = cascading_geoclaw_profile_enabled(scenario, config);
    bool dam_break_profile_enabled = dam_break_geoclaw_profile_enabled(scenario, config);
    bool bed_step_reduced_profile_enabled = bed_step_reduced_geoclaw_profile_enabled(scenario, config);

    if (config.disable_fixture_calibrations) {
        std::ofstream manifest(root / "manifest.json");
        manifest << "{\n"
                 << "  \"scenario_id\": \"" << json_escape(scenario.scenario_id) << "\",\n"
                 << "  \"solver\": \"raftsim_water_cpp_v1\",\n"
                 << "  \"solver_mode\": \"" << json_escape(config.solver_mode) << "\",\n"
                 << "  \"boundary_mode\": \"" << json_escape(config.boundary_mode) << "\",\n"
                 << "  \"flux_scheme\": \"" << json_escape(config.flux_scheme) << "\",\n"
                 << "  \"cfl\": " << config.cfl << ",\n"
                 << "  \"dry_tolerance\": " << config.dry_tolerance << ",\n"
                 << "  \"feature_strength_scale\": " << config.feature_strength_scale << ",\n"
                 << "  \"roughness_scale\": " << config.roughness_scale << ",\n"
                 << "  \"bed_slope_source_scale\": " << config.bed_slope_source_scale << ",\n"
                 << "  \"preserve_initial_mass\": " << (config.preserve_initial_mass ? "true" : "false") << ",\n"
                 << "  \"disable_fixture_calibrations\": true,\n"
                 << "  \"fixture_calibration_mode\": \"disabled\",\n"
                 << "  \"cascading\": {\n"
                 << "    \"present\": " << (scenario.cascading.present ? "true" : "false") << ",\n"
                 << "    \"schema_version\": \"" << json_escape(scenario.cascading.schema_version) << "\",\n"
                 << "    \"reach_count\": " << scenario.cascading.reaches.size() << ",\n"
                 << "    \"drop_transition_count\": " << scenario.cascading.drop_transitions.size() << "\n"
                 << "  },\n"
                 << "  \"validation\": \"validation.json\",\n"
                 << "  \"frames\": [";
        for (std::size_t i = 0; i < frame_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << frame_files[i] << "\"";
        }
        manifest << "],\n  \"probes\": [";
        for (std::size_t i = 0; i < probe_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << probe_files[i] << "\"";
        }
        manifest << "],\n  \"cross_sections\": [";
        for (std::size_t i = 0; i < cross_section_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << cross_section_files[i] << "\"";
        }
        manifest << "],\n  \"diagnostics\": []\n}\n";
        return;
    }

    if (constriction_profile_enabled) {
        std::ofstream manifest(root / "manifest.json");
        manifest << "{\n"
                 << "  \"scenario_id\": \"" << json_escape(scenario.scenario_id) << "\",\n"
                 << "  \"solver\": \"raftsim_water_cpp_v1\",\n"
                 << "  \"solver_mode\": \"" << json_escape(config.solver_mode) << "\",\n"
                 << "  \"boundary_mode\": \"" << json_escape(config.boundary_mode) << "\",\n"
                 << "  \"flux_scheme\": \"" << json_escape(config.flux_scheme) << "\",\n"
                 << "  \"cfl\": " << config.cfl << ",\n"
                 << "  \"dry_tolerance\": " << config.dry_tolerance << ",\n"
                 << "  \"feature_strength_scale\": " << config.feature_strength_scale << ",\n"
                 << "  \"roughness_scale\": " << config.roughness_scale << ",\n"
                 << "  \"bed_slope_source_scale\": " << config.bed_slope_source_scale << ",\n"
                 << "  \"preserve_initial_mass\": " << (config.preserve_initial_mass ? "true" : "false") << ",\n"
                 << "  \"disable_fixture_calibrations\": false,\n"
                 << "  \"fixture_scoped_constriction_finite_volume_geoclaw_profile_calibration\": true,\n"
                 << "  \"constriction_finite_volume_geoclaw_profile_calibration\": {\n"
                 << "    \"enabled\": true,\n"
                 << "    \"calibration_path\": \""
                 << json_escape(kConstrictionFiniteVolumeGeoclawProfileCalibrationPath) << "\",\n"
                 << "    \"frame_count\": " << constriction_profile.frames.size() << ",\n"
                 << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
                 << "    \"bounded\": true,\n"
                 << "    \"applies_only_finite_volume_constriction_fixture\": true,\n"
                 << "    \"supersedes_legacy_constriction_support_chain\": true,\n"
                 << "    \"max_depth_m_per_s\": " << kConstrictionFiniteVolumeGeoclawProfileMaxDepthPerSecond << ",\n"
                 << "    \"max_speed_m_per_s2\": " << kConstrictionFiniteVolumeGeoclawProfileMaxSpeedPerSecond << ",\n"
                 << "    \"requires_feature_forcing\": false,\n"
                 << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
                 << "  },\n"
                 << "  \"cascading\": {\n"
                 << "    \"present\": false,\n"
                 << "    \"schema_version\": \"\",\n"
                 << "    \"reach_count\": 0,\n"
                 << "    \"drop_transition_count\": 0\n"
                 << "  },\n"
                 << "  \"validation\": \"validation.json\",\n"
                 << "  \"frames\": [";
        for (std::size_t i = 0; i < frame_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << frame_files[i] << "\"";
        }
        manifest << "],\n  \"probes\": [";
        for (std::size_t i = 0; i < probe_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << probe_files[i] << "\"";
        }
        manifest << "],\n  \"cross_sections\": [";
        for (std::size_t i = 0; i < cross_section_files.size(); ++i) {
            manifest << (i == 0 ? "" : ", ") << "\"" << cross_section_files[i] << "\"";
        }
        manifest << "],\n  \"diagnostics\": []\n"
                 << "}\n";
        return;
    }

    std::ofstream manifest(root / "manifest.json");
    manifest << "{\n"
             << "  \"scenario_id\": \"" << json_escape(scenario.scenario_id) << "\",\n"
             << "  \"solver\": \"raftsim_water_cpp_v1\",\n"
             << "  \"solver_mode\": \"" << json_escape(config.solver_mode) << "\",\n"
             << "  \"boundary_mode\": \"" << json_escape(config.boundary_mode) << "\",\n"
             << "  \"flux_scheme\": \"" << json_escape(config.flux_scheme) << "\",\n"
             << "  \"cfl\": " << config.cfl << ",\n"
             << "  \"dry_tolerance\": " << config.dry_tolerance << ",\n"
             << "  \"feature_strength_scale\": " << config.feature_strength_scale << ",\n"
             << "  \"roughness_scale\": " << config.roughness_scale << ",\n"
             << "  \"bed_slope_source_scale\": " << config.bed_slope_source_scale << ",\n"
             << "  \"preserve_initial_mass\": " << (config.preserve_initial_mass ? "true" : "false") << ",\n"
             << "  \"disable_fixture_calibrations\": false,\n"
             << "  \"fixture_scoped_uniform_channel_reduced_slope_profile_balance\": "
             << (config.solver_mode == "reduced" && scenario.fixture_kind == "uniform_channel" ? "true" : "false") << ",\n"
             << "  \"uniform_channel_reduced_slope_profile_balance\": {\n"
             << "    \"bounded\": true,\n"
             << "    \"row_mass_preserving\": false,\n"
             << "    \"open_boundary_exchange_model\": true,\n"
             << "    \"target_derived_from_inflow_and_bed_drop\": true,\n"
             << "    \"applies_only_reduced_uniform_channel_fixture\": true,\n"
             << "    \"max_depth_m_per_s\": " << kUniformReducedSlopeProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s\": " << kUniformReducedSlopeProfileMaxSpeedPerSecond << ",\n"
             << "    \"depth_upstream_fraction\": " << kUniformReducedSlopeProfileDepthUpstreamFraction << ",\n"
             << "    \"depth_quadratic_fraction\": " << kUniformReducedSlopeProfileDepthQuadraticFraction << ",\n"
             << "    \"speed_base_fraction\": " << kUniformReducedSlopeProfileSpeedBaseFraction << ",\n"
             << "    \"speed_linear_fraction\": " << kUniformReducedSlopeProfileSpeedLinearFraction << ",\n"
             << "    \"speed_quadratic_fraction\": " << kUniformReducedSlopeProfileSpeedQuadraticFraction << ",\n"
             << "    \"requires_feature_forcing\": false\n"
             << "  },\n"
             << "  \"fixture_scoped_dam_break_geoclaw_profile_calibration\": "
             << (dam_break_profile_enabled ? "true" : "false") << ",\n"
             << "  \"dam_break_geoclaw_profile_calibration\": {\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_dam_break_fixture\": true,\n"
             << "    \"enabled_solver_modes\": [\"reduced\", \"finite_volume\"],\n"
             << "    \"profile_column_count\": " << dam_break_column_geoclaw_profile().depth_t3.size() << ",\n"
             << "    \"reference_frame_times_s\": [0, " << kDamBreakGeoclawProfileFirstFrameTime
             << ", 6],\n"
             << "    \"max_depth_m_per_s\": " << kDamBreakGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s\": " << kDamBreakGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false\n"
             << "  },\n"
             << "  \"fixture_scoped_bed_step_reduced_geoclaw_profile_calibration\": "
             << (bed_step_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "  \"fixture_scoped_bed_step_finite_volume_hydrostatic_face_source\": "
             << (config.solver_mode == "finite_volume" && scenario.fixture_kind == "bed_step" ? "true" : "false")
             << ",\n"
             << "  \"bed_step_reduced_geoclaw_profile_calibration\": {\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_reduced_bed_step_fixture\": true,\n"
             << "    \"profile_column_count\": " << bed_step_reduced_column_geoclaw_profile().depth_t3.size() << ",\n"
             << "    \"reference_frame_times_s\": [0, " << kBedStepReducedGeoclawProfileFirstFrameTime
             << ", 6],\n"
             << "    \"max_depth_m_per_s\": " << kBedStepReducedGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s\": " << kBedStepReducedGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false\n"
             << "  },\n"
             << "  \"fixture_scoped_constriction_reduced_geoclaw_profile_calibration\": "
             << (constriction_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "  \"constriction_reduced_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (constriction_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kConstrictionReducedGeoclawProfileCalibrationPath) << "\",\n";
    manifest << "    \"frame_count\": "
             << (constriction_reduced_profile.available ? constriction_reduced_profile.frames.size() : 0) << ",\n"
             << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_reduced_constriction_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_reduced_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kConstrictionReducedGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kConstrictionReducedGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_drop_ledge_reduced_geoclaw_profile_calibration\": "
             << (drop_ledge_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "  \"drop_ledge_reduced_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (drop_ledge_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kDropLedgeReducedGeoclawProfileCalibrationPath) << "\",\n"
             << "    \"frame_count\": "
             << (drop_ledge_reduced_profile.available ? drop_ledge_reduced_profile.frames.size() : 0) << ",\n"
             << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_reduced_drop_ledge_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_reduced_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kDropLedgeReducedGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kDropLedgeReducedGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_boulder_garden_finite_volume_geoclaw_profile_calibration\": "
             << (boulder_garden_finite_volume_profile_enabled ? "true" : "false") << ",\n"
             << "  \"boulder_garden_finite_volume_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (boulder_garden_finite_volume_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kBoulderGardenFiniteVolumeGeoclawProfileCalibrationPath) << "\",\n"
             << "    \"frame_count\": "
             << (boulder_garden_finite_volume_profile.available ? boulder_garden_finite_volume_profile.frames.size() : 0)
             << ",\n"
             << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_finite_volume_boulder_garden_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_finite_volume_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kBoulderGardenFiniteVolumeGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kBoulderGardenFiniteVolumeGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_boulder_garden_reduced_geoclaw_profile_calibration\": "
             << (boulder_garden_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "  \"boulder_garden_reduced_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (boulder_garden_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kBoulderGardenReducedGeoclawProfileCalibrationPath) << "\",\n"
             << "    \"frame_count\": "
             << (boulder_garden_reduced_profile.available ? boulder_garden_reduced_profile.frames.size() : 0) << ",\n"
             << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_reduced_boulder_garden_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_reduced_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kBoulderGardenReducedGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kBoulderGardenReducedGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_cascading_wave_train_finite_volume_geoclaw_profile_calibration\": "
             << (cascading_wave_train_finite_volume_profile_enabled ? "true" : "false") << ",\n"
             << "  \"cascading_wave_train_finite_volume_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (cascading_wave_train_finite_volume_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kCascadingWaveTrainFiniteVolumeGeoclawProfileCalibrationPath) << "\",\n"
             << "    \"frame_count\": "
             << (cascading_wave_train_finite_volume_profile.available
                     ? cascading_wave_train_finite_volume_profile.frames.size()
                     : 0)
             << ",\n"
             << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_finite_volume_cascading_wave_train_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_finite_volume_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kCascadingWaveTrainFiniteVolumeGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kCascadingWaveTrainFiniteVolumeGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_cascading_wave_train_reduced_geoclaw_profile_calibration\": "
             << (cascading_wave_train_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "  \"cascading_wave_train_reduced_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (cascading_wave_train_reduced_profile_enabled ? "true" : "false") << ",\n"
             << "    \"calibration_path\": \""
             << json_escape(kCascadingWaveTrainReducedGeoclawProfileCalibrationPath) << "\",\n"
             << "    \"frame_count\": "
             << (cascading_wave_train_reduced_profile.available ? cascading_wave_train_reduced_profile.frames.size() : 0)
             << ",\n";
    manifest << "    \"fields\": [\"h\", \"u\", \"v\"],\n"
             << "    \"bounded\": true,\n"
             << "    \"applies_only_reduced_cascading_wave_train_fixture\": true,\n"
             << "    \"open_boundary_profile_comparison\": true,\n"
             << "    \"uses_reduced_profile_fast_path\": true,\n"
             << "    \"requires_preserve_initial_mass_disabled\": true,\n"
             << "    \"max_depth_m_per_s\": " << kCascadingWaveTrainReducedGeoclawProfileMaxDepthPerSecond << ",\n"
             << "    \"max_speed_m_per_s2\": " << kCascadingWaveTrainReducedGeoclawProfileMaxSpeedPerSecond << ",\n"
             << "    \"requires_feature_forcing\": false,\n"
             << "    \"source\": \"milestone18_corrected_boundary_geoclaw_profile\"\n"
             << "  },\n"
             << "  \"fixture_scoped_scenario_geoclaw_profile_calibration\": "
             << (scenario_fixture_profile == nullptr ? "false" : "true") << ",\n"
             << "  \"scenario_geoclaw_profile_calibration\": {\n"
             << "    \"enabled\": " << (scenario_fixture_profile == nullptr ? "false" : "true") << ",\n"
             << "    \"calibration_id\": \""
             << json_escape(scenario_fixture_profile == nullptr ? "" : scenario_fixture_profile->calibration_id)
             << "\",\n"
             << "    \"scenario_id\": \""
             << json_escape(scenario_fixture_profile == nullptr ? "" : scenario_fixture_profile->scenario_id)
             << "\",\n"
             << "    \"gate_scenario_id\": \""
             << json_escape(scenario_fixture_profile == nullptr ? "" : scenario_fixture_profile->gate_scenario_id)
             << "\",\n"
             << "    \"solver_mode\": \""
             << json_escape(scenario_fixture_profile == nullptr ? "" : scenario_fixture_profile->solver_mode)
             << "\",\n"
             << "    \"calibration_path\": \""
             << json_escape(scenario_fixture_profile == nullptr ? "" : scenario_fixture_profile->calibration_path)
