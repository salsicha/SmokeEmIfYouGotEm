{
  "schema": "raftsim.unreal.first_rapid_vertical_slice.v1",
  "game_mode": "ARaftSimVerticalSliceGameMode",
  "default_pawn": "ARaftSimGuidePawn",
  "map": "/Game/RaftSim/Maps/L_RaftSimBoot",
  "scenario_sources": {
    "validated_river_package": "physics/data/real_world/south_fork_american_chili_bar/scenario/scenario.json",
    "validated_feature_package": "physics/data/real_world/south_fork_american_chili_bar/scenario/features.json",
    "rapid_review_flow_mapping": "physics/data/real_world/south_fork_american_chili_bar/rapid_review_flow_difficulty_mapping.json",
    "river_selection_catalog": "unreal/Content/RaftSim/UI/river_selection_catalog.json",
    "live_water_bridge": "unreal/Content/RaftSim/Physics/live_water_bridge.json",
    "raft_contact_authority": "unreal/Content/RaftSim/Physics/raft_contact_authority_integration.json",
    "crew_safety_states": "unreal/Content/RaftSim/Crew/crew_overboard_safety_states.json",
    "swimmer_rescue_gameplay": "unreal/Content/RaftSim/Crew/swimmer_rescue_gameplay.json",
    "scoring": "unreal/Content/RaftSim/Crew/gameplay_telemetry_scoring.json",
    "replay_manifest": "physics/data/readiness/milestone_10/unreal_visualization/manifest.json",
    "telemetry_presentation_cues": "unreal/Content/RaftSim/Rendering/telemetry_presentation_cues.json",
    "environment_corridor": "unreal/Content/RaftSim/Rendering/vertical_slice_environment_corridor.json"
  },
  "runtime_contract": {
    "water_authority": "custom_cxx_shallow_water_solver",
    "raft_contact_authority": "CustomReducedRigidBody",
    "render_tick_may_advance_authority": false,
    "crew_safety_states_enabled": true,
    "swimming_skill_assignment_enabled": true,
    "scoring_enabled": true,
    "telemetry_driven_presentation_enabled": true,
    "photoreal_environment_corridor_enabled": true,
    "restart_enabled": true,
    "replay_enabled": true,
    "after_action_feedback_enabled": true
  },
  "scenarios": [
    {
      "scenario_id": "training_eddy_turn_intro",
      "kind": "training_section",
      "display_name": "Training Eddy Turn Intro",
      "river_id": "american_south_fork",
      "section_id": "chili_bar_to_coloma",
      "flow_band": "low_runnable",
      "difficulty_preset": "beginner",
      "station_window_m": [0.0, 120.0],
      "focus_features": ["rapid_candidate_01"],
      "objectives": [
        "forward_paddle_timing",
        "brace_on_wave",
        "hold_on_before_lateral",
        "catch_recovery_eddy",
        "quick_restart",
        "after_action_feedback"
      ],
      "expected_outcomes": ["flush", "recover", "guided_avoidance"],
      "failure_states": ["missed_eddy", "late_brace", "passenger_at_risk"],
      "training_lessons": ["forward_paddle", "back_paddle", "brace", "hold_on", "eddy_turn_intro"]
    },
    {
      "scenario_id": "first_technical_constriction_wave_train",
      "kind": "technical_rapid",
      "display_name": "First Technical Constriction Wave Train",
      "river_id": "american_south_fork",
      "section_id": "chili_bar_to_coloma",
      "flow_band": "median_runnable",
      "difficulty_preset": "intermediate",
      "station_window_m": [90.0, 135.0],
      "focus_features": ["rapid_candidate_02", "paired_wave_train"],
      "objectives": [
        "read_entry_tongue",
        "hold_boat_angle",
        "manual_or_voice_crew_commands",
        "brace_or_high_side_counterplay",
        "recover_swimmer_if_ejected",
        "score_and_replay_review"
      ],
      "expected_outcomes": ["clean_line", "surf", "flush", "brief_pin"],
      "failure_states": ["sideways_lateral_hit", "missed_high_side", "swimmer", "failed_rescue"]
    }
  ],
  "scoring": {
    "manifest": "unreal/Content/RaftSim/Crew/gameplay_telemetry_scoring.json",
    "breakdown": [
      "safety",
      "line_choice",
      "boat_angle",
      "paddle_efficiency",
      "crew_trust",
      "command_timing",
      "high_side_brace_timing",
      "swims_and_rescue"
    ],
    "after_action_feedback": true,
    "feedback_sections": [
      "line_summary",
      "safety_summary",
      "command_timing",
      "boat_angle",
      "paddle_efficiency",
      "rescue_and_recovery",
      "replay_bookmarks"
    ]
  },
  "restart": {
    "quick_restart": true,
    "reset_score": true,
    "reset_replay_frame": true,
    "reset_crew_safety_state": true,
    "preserve_selected_scenario": true
  },
  "replay": {
    "enabled": true,
    "source_first": "telemetry_playback_before_live_physics",
    "live_capture_path": "Saved/Automation/RaftSim/VerticalSlice/live_run_capture.jsonl",
    "bookmarks": ["entry", "first_contact", "command_window", "rescue_window", "finish"]
  },
  "debug_force_visualization": {
    "enabled": true,
    "vectors": [
      "buoyancy",
      "drag",
      "added_mass",
      "paddle",
      "contact",
      "eddy_shear",
      "boil_upwelling"
    ],
    "contacts": ["rock", "bed", "bank", "ledge", "strainer"]
  },
  "presentation": {
    "cue_manifest": "unreal/Content/RaftSim/Rendering/telemetry_presentation_cues.json",
    "blueprint_function": "URaftSimTelemetryPresentationCueLibrary::BuildPresentationCues",
    "driven_by": [
      "custom_cxx_water_solver",
      "raft_contact_authority",
      "crew_safety_state",
      "paddle_input_runtime",
      "weather_runtime",
      "replay_telemetry"
    ],
    "visual_targets": [
      "readable_water_materials",
      "foam",
      "spray",
      "wet_rocks",
      "raft_contact_cues",
      "paddle_cues",
      "rescue_cues"
    ],
    "audio_targets": [
      "3d_spatial_water",
      "ambisonic_ambience",
      "raft_contact_audio",
      "paddle_audio",
      "weather_audio",
      "reverb",
      "occlusion",
      "rescue_callouts"
    ]
  },
  "environment": {
    "corridor_manifest": "unreal/Content/RaftSim/Rendering/vertical_slice_environment_corridor.json",
    "data_asset_class": "URaftSimVerticalSliceEnvironmentConfig",
    "required_layers": [
      "landscape_and_bed",
      "banks_and_channel_edges",
      "rocks_boulders_and_ledges",
      "riverbank_foliage",
      "driftwood_debris_access_context",
      "lighting_weather_and_atmosphere",
      "audio_occlusion_and_reverb_geometry",
      "water_readability_support"
    ],
    "quality_targets": [
      "photoreal_guide_seat_capture",
      "desktop_high_budget",
      "vr_comfort_budget",
      "replay_review_alignment"
    ]
  },
  "pass_policy": {
    "has_training_section": true,
    "has_technical_rapid": true,
    "uses_validated_river_data": true,
    "uses_live_custom_water_contract": true,
    "uses_selected_raft_contact_authority": true,
    "uses_crew_safety_states": true,
    "uses_telemetry_driven_presentation_cues": true,
    "uses_photoreal_environment_corridor": true,
    "supports_scoring_restart_replay_after_action_feedback": true
  },
  "status": "vertical_slice_training_and_technical_rapid_contract_ready_for_map_authoring"
}
