        "river_selection_catalog",
        "alpha_systems_progression",
        "crew_conversation_bark_catalog",
        "networked_crew_gate"
      ],
      "blocks_alpha_promotion": true
    },
    {
      "lane_id": "physics_regression_replay",
      "requirement": "Playable alpha routes must replay against the accepted water report lock, live-water smoke gate, analytic guardrails, feature/raft fixtures, and deterministic replay evidence.",
      "evidence": [
        "physics/reports/milestone20/report_set_lock.json",
        "physics/reports/milestone20/live_water_unreal_smoke_suite.json",
        "unreal/Content/RaftSim/Automation/live_water_smoke_suite.json",
        "unreal/Content/RaftSim/River/round_trip_validation.json"
      ],
      "blocks_alpha_promotion": true
    },
    {
      "lane_id": "river_source_provenance",
      "requirement": "Every river promoted into alpha must preserve source manifest id, CRS, transform, flow-band metadata, license/terms, rights/provenance status, guide-review annotations, and field-media rights.",
      "evidence": [
        "physics/data/real_world/south_fork_american_chili_bar/source_manifest.json",
        "physics/data/real_world/colorado_river_grand_canyon_rowing/source_manifest.json",
        "physics/data/real_world/pacuare_river_costa_rica/source_manifest.json",
        "physics/data/real_world/source_catalog.json"
      ],
      "blocks_alpha_promotion": true
    },
    {
      "lane_id": "playable_end_to_end_runs",
      "requirement": "Every playable alpha river section must run end-to-end from selection through launch, completion/failure, restart, scoring, replay review, and after-action feedback.",
      "evidence": [
        "unreal/Content/RaftSim/Automation/vertical_slice_acceptance_gate.json",
        "physics/reports/milestone23/vertical_slice_acceptance_gate.json"
      ],
      "blocks_alpha_promotion": true
    }
  ],
  "river_run_targets": [
