{
  "schema": "raftsim.unreal.guide_camera_config.v1",
  "pawn_class": "ARaftSimGuidePawn",
  "perspective": "first_person_stern_guide",
  "anchors": {
    "guide_seat_local_cm": [-180.0, 0.0, 45.0],
    "view_origin_local_cm": [0.0, 0.0, 0.0],
    "paddle_anchor_local_cm": [25.0, -65.0, -20.0],
    "left_hand_anchor_local_cm": [30.0, -38.0, -32.0],
    "right_hand_anchor_local_cm": [30.0, 38.0, -32.0],
    "camera_local_cm": [0.0, 0.0, 0.0],
    "raft_bow_reference_local_cm": [280.0, 0.0, 20.0],
    "left_tube_reference_local_cm": [45.0, -85.0, 4.0],
    "right_tube_reference_local_cm": [45.0, 85.0, 4.0],
    "passenger_silhouette_reference_local_cm": [70.0, 0.0, 50.0]
  },
  "flat_screen": {
    "mouse_look": true,
    "gamepad_look": true,
    "impact_filtering": true,
    "camera_fov_degrees": 90.0
  },
  "vr": {
    "seated_recenter": true,
    "horizon_stabilization": true,
    "comfort_vignette": true,
    "head_locked_ui": false,
    "motion_intensity": 0.65,
    "impact_filter_speed": 10.0,
    "horizon_stabilization_strength": 0.75,
    "comfort_vignette_strength": 0.35
  },
  "haptics": {
    "impact_pulses": true,
    "impact_threshold": 0.25,
    "runtime_output": "ConsumePendingHapticPulse"
  },
  "accessibility": {
    "comfort_mode": true,
    "accessibility_motion_scale": 0.45,
    "manual_recenter_action": "RecenterVR",
    "visible_grounding_references": [
      "hands",
      "paddle",
      "raft_bow",
      "left_tube",
      "right_tube",
      "passenger_silhouettes"
    ]
  }
}
