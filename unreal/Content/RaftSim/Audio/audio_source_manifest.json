{
  "schema": "raftsim.unreal.audio_source_manifest.v2",
  "production_policy": {
    "development_backbone": "free_open_first_party_generated_procedural_and_ai_generated_audio",
    "paid_asset_decision": "defer_until_release_readiness_gate",
    "buy_paid_assets_only_if_free_open_and_ai_generated_assets_are_not_good_enough": true,
    "ai_audio_role": "development_allowed_shipping_requires_release_gate_review",
    "manifest_required_for_every_asset": true
  },
  "initial_source_choices": [
    {
      "category": "river_water_beds_and_rapids",
      "preferred_sources": [
        "ai_generated_development_assets",
        "cc0_or_public_domain_water_sources",
        "cc_by_sources_with_attribution",
        "first_party_procedural_water_audio"
      ],
      "shipping_status": "development_only_until_release_gate"
    },
    {
      "category": "raft_paddle_rock_impacts",
      "preferred_sources": [
        "ai_generated_development_assets",
        "first_party_generated_foley",
        "free_open_foley_sources",
        "first_party_recordings_without_paid_asset_license"
      ],
      "shipping_status": "development_only_until_release_gate"
    },
    {
      "category": "weather_wind_rain_spray",
      "preferred_sources": [
        "ai_generated_development_assets",
        "cc0_or_public_domain_weather_sources",
        "cc_by_sources_with_attribution",
        "first_party_procedural_weather_audio"
      ],
      "shipping_status": "development_only_until_release_gate"
    },
    {
      "category": "gear_foley_pfd_helmet_rope",
      "preferred_sources": [
        "ai_generated_development_assets",
        "first_party_generated_foley",
        "free_open_foley_sources",
        "first_party_recordings_without_paid_asset_license"
      ],
      "shipping_status": "development_only_until_release_gate"
    },
    {
      "category": "ui_training_debug",
      "preferred_sources": [
        "authored_synth",
        "procedural_audio",
        "ai_generated_development_assets",
        "free_open_ui_audio"
      ],
      "shipping_status": "development_only_until_release_gate"
    },
    {
      "category": "ambisonic_canyon_forest_ambience",
      "preferred_sources": [
        "ai_generated_development_assets",
        "free_open_ambience_sources",
        "first_party_recordings_without_paid_asset_license",
        "procedural_ambience_beds"
      ],
      "shipping_status": "development_only_until_release_gate"
    }
  ],
  "paid_research_reference_sources": [
    "BOOM Library",
    "Pro Sound Effects",
    "A Sound Effect",
    "Soundly",
    "Fab",
    "Sound Ideas",
    "Sounddogs",
    "BBC Sound Effects"
  ],
  "asset_record_fields": [
    "asset_id",
    "filename",
    "source",
    "license_or_purchase_record",
    "attribution_requirement",
    "commercial_use_status",
    "allowed_platforms",
    "sample_rate",
    "bit_depth",
    "channels",
    "mic_setup",
    "location_date_recordist",
    "processing_chain",
    "loop_points",
    "ucs_metadata",
    "attenuation_preset",
    "spatialization_mode",
    "ambisonic_format_order",
    "reverb_occlusion_behavior",
    "intended_playback_context",
    "approval_status"
  ],
  "unreal_import_defaults": {
    "sample_rate_hz": 48000,
    "loudness_target_lufs": -23,
    "raw_and_master_audio_in_lfs": true
  }
}
