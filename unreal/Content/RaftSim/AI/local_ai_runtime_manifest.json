{
  "schema": "raftsim.unreal.local_ai_runtime.v1",
  "module": "RaftSimAI",
  "privacy_policy": "offline_first_no_cloud_required_for_core_gameplay",
  "gameplay_mode_policy": {
    "guided_passenger_paddle_raft": "voice_or_manual_crew_commands",
    "rowing_oar_rig": "manual_oar_controls_only_voice_commands_disabled"
  },
  "layers": [
    {
      "layer": "speech_recognition",
      "interface": "IRaftSimSpeechRecognizer",
      "purpose": "convert guide speech into transcript and confidence"
    },
    {
      "layer": "command_intent_parser",
      "purpose": "map transcript into deterministic crew command intents through a normalized phrase grammar"
    },
    {
      "layer": "deterministic_command_router",
      "interface": "URaftSimVoiceCommandRouter",
      "purpose": "apply gameplay mode gates, confidence thresholds, latency limits, confirmation behavior, and telemetry before command execution"
    },
    {
      "layer": "crew_dialogue",
      "interface": "IRaftSimCrewDialogueProvider",
      "purpose": "select or generate non-critical crew conversation lines"
    },
    {
      "layer": "local_tts_optional",
      "purpose": "prototype crew voice rendering when approved audio assets are unavailable"
    }
  ],
  "runtime_constraints": {
    "core_paddling_commands_must_be_deterministic": true,
    "cloud_ai_not_required": true,
    "manual_input_parity_required": true,
    "rowing_oar_rig_voice_commands_enabled": false,
    "command_model_profile": "lightweight_efficient_accurate_local",
    "broad_conversation_model_allowed_for_gameplay_commands": false,
    "execute_confidence_threshold": 0.78,
    "confirm_confidence_threshold": 0.58,
    "max_command_latency_ms": 240.0,
    "optimize_for": [
      "accuracy",
      "low_latency",
      "low_memory",
      "low_cpu_gpu_cost",
      "noisy_river_robustness"
    ]
  }
}
