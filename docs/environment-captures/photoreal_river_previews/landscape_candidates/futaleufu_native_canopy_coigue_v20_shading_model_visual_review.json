  "source_texture_observation": {
    "transparent_rgb_current_behavior": "The generator sets RGB to zero wherever alpha is at most 2/255.",
    "distance_risk": "Sharpened alpha-coverage mips can retain opacity while filtering transparent black RGB into the surviving leaf color.",
    "required_fix_boundary": "Pad RGB only within each atlas tile, preserve the alpha channel and opaque RGB byte-for-byte, and repeat the same corridor captures before changing opacity or reflectance defaults."
  },
  "accepted_findings": [
    "The same-texture masked DefaultLit diagnostic compiles, persists instanced usage, and renders all near, mid, and runtime-far representations.",
    "At equal reflectance, DefaultLit reduces green crown response and increases darkness relative to native TwoSidedFoliage in both views.",
    "The native TwoSidedFoliage shading model is retained and no diagnostic material is promoted.",
    "The comparison preserves identical 1,200-tree placement counts, source map, saved photometry, geometry, and physics authority."
  ],
  "rejection_reasons": [
    "DefaultLit does not correct the dark crowns and performs substantially worse at the 2.36 reflectance control.",
    "The diagnostic omits foliage subsurface transmission and is not physically suitable for production leaves.",
    "All captures retain the alpha4 solid-card appearance and fail lifelike forest readability.",
    "Changing shading model would treat a symptom while leaving transparent-black mip contamination intact."
  ],
  "next_iteration_requirements": [
    "Add deterministic per-tile RGB padding around the leaf silhouettes while preserving alpha and opaque RGB exactly.",
    "Record alpha and opaque-RGB hashes plus padding radius in the source manifest and regression tests.",
    "Reimport the corrected texture, rebuild native TwoSidedFoliage, and repeat the alpha4 neutral-reflectance corridor pair.",
    "Only after confirming color preservation should opacity scale be reduced toward leaf-shaped breakup."
  ]
